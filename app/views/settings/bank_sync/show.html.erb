<%= content_for :page_title, t("settings.bank_sync.page_title") %>

<div class="space-y-4">
  <%= settings_section title: t("settings.bank_sync.gmail_title"), subtitle: t("settings.bank_sync.gmail_subtitle"), collapsible: true, open: true do %>
    <%= render "mail_sync_panel",
               mail_connection: @mail_connection,
               bank_formats: @bank_formats,
               bank_links: @bank_links,
               mail_sync_configured: @mail_sync_configured,
               mail_sync_issues: @mail_sync_issues,
               mail_sync_imports: @mail_sync_imports %>
  <% end %>

  <% if Current.user.admin? %>
    <%= settings_section title: t("settings.bank_sync.patterns_title"), subtitle: t("settings.bank_sync.patterns_subtitle"), collapsible: true, open: false do %>
      <%= render "pattern_admin", bank_formats: @bank_formats %>
    <% end %>
  <% end %>

  <%= settings_section title: t("settings.bank_sync.providers_title"), collapsible: true, open: false do %>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <% if @providers.any? %>
        <div class="rounded-xl bg-container-inset space-y-1 p-1">
          <div class="flex items-center gap-1.5 px-4 py-2 text-xs font-medium text-secondary uppercase">
            <p><%= t("settings.bank_sync.providers_label") %></p>
            <span class="text-subdued">&middot;</span>
            <p><%= @providers.count %></p>
          </div>

          <div class="bg-container rounded-lg shadow-border-xs">
            <div class="overflow-hidden rounded-lg">
              <%= render partial: "provider_link", collection: @providers, spacer_template: "shared/ruler" %>
            </div>
          </div>
        </div>
      <% else %>
        <div class="flex justify-center items-center py-12">
          <div class="text-center flex flex-col items-center max-w-[300px]">
            <p class="text-primary mb-1 font-medium text-sm"><%= t("settings.bank_sync.no_providers") %></p>
            <p class="text-secondary text-sm"><%= t("settings.bank_sync.no_providers_hint") %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

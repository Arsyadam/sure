<%# locals: (bank_formats:) %>

<div class="space-y-4">
  <p class="text-secondary text-sm"><%= t("settings.bank_sync.patterns_admin_hint") %></p>

  <% bank_formats.each do |format| %>
    <div class="p-4 rounded-lg bg-container-inset border border-primary space-y-3">
      <div>
        <p class="text-primary font-medium text-sm"><%= format.name %> (<%= format.code %>)</p>
        <p class="text-secondary text-xs"><%= format.sender_email %></p>
      </div>

      <%= form_with url: format_settings_bank_sync_path(format), method: :patch, class: "space-y-3" do %>
        <% MailBankFormat::PATTERN_FIELDS.each do |field| %>
          <div>
            <label class="text-xs text-secondary"><%= t("settings.bank_sync.pattern_#{field}") %></label>
            <%= text_field_tag "mail_bank_format[patterns][#{field}]",
                               format.patterns[field],
                               class: "w-full rounded-md border border-secondary bg-container px-3 py-2 font-mono text-xs",
                               placeholder: t("settings.bank_sync.pattern_placeholder") %>
          </div>
        <% end %>

        <label class="flex items-center gap-2 text-sm text-primary">
          <%= check_box_tag "mail_bank_format[enabled]", "1", format.enabled?, class: "rounded border-secondary" %>
          <%= t("settings.bank_sync.format_enabled") %>
        </label>

        <div class="flex justify-end">
          <%= submit_tag t("settings.bank_sync.save_patterns"), class: "inline-flex items-center px-3 py-2 text-sm font-medium text-inverse bg-inverse hover:bg-inverse-hover rounded-lg cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
